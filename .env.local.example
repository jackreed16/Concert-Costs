# Copy this file to .env.local and fill in your ConcertCosts project values.
# Get these from Supabase: open ConcertCosts → Connect (or Settings → API Keys).
# Use the Project URL and the publishable key (or anon public key). Never use the service role key here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Optional: production site URL for password-reset emails (e.g. https://your-app.vercel.app)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
